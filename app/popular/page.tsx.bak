            { name: 'สินค้ายอดนิยม', href: '/popular', icon: '📈', active: true },
            { name: 'เปรียบเทียบ', href: '/compare', icon: '⚖️' },
            { name: 'แจ้งเตือนราคา', href: '/alerts', icon: '🔔' },
            { name: 'ประวัติการเข้าชม', href: '/history', icon: '📋' },
            { name: 'รายการโปรด', href: '/favorites', icon: '❤️' },
